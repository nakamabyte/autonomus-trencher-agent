TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TOPIC_ID=

# ─── Twitter/X Bot ─────────────────────────────────────────────────
TWITTER_ENABLED=true
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ─── Tweet Settings ────────────────────────────────────────────────
TWEET_ON_OPEN=true
TWEET_ON_CLOSE=true
TWEET_ON_DAILY_SUMMARY=true
TWEET_ON_SCREENING=true
TWEET_MIN_CONFIDENCE=0.0
# Signal server — contact maintainer for access
SIGNAL_SERVER_URL=https://api.thecharon.xyz/api
SIGNAL_SERVER_KEY=
SIGNAL_POLL_MS=30000

# Helius RPC — required for live execution; free tier works for dry_run
HELIUS_API_KEY=
SOLANA_RPC_URL=
SOLANA_WS_URL=

# GMGN enrichment — set GMGN_ENABLED=false to skip (falls back to Jupiter data)
GMGN_ENABLED=true
GMGN_API_KEY=
GMGN_REQUEST_DELAY_MS=2500
GMGN_MAX_RETRIES=2

DB_PATH=./trencher-agent.sqlite
TRADING_MODE=dry_run

# Live / confirm execution — wallet + Jupiter API key required
SOLANA_PRIVATE_KEY=
JUPITER_API_KEY=
JUPITER_SWAP_BASE_URL=https://api.jup.ag/swap/v2
LIVE_MIN_SOL_RESERVE=0.02

# LLM — Multi-Agent Configuration
ENABLE_LLM=true
LLM_MULTI_AGENT=true

# ─── TIER 1: DeepSeek (Bulk Screener) ─────────────────────────────
LLM_T1_BASE_URL=https://api.deepseek.com/v1
LLM_T1_API_KEY=
LLM_T1_MODEL=deepseek-chat
LLM_T1_CONFIDENCE_PASS=0.75
LLM_T1_CONFIDENCE_BUY=0.80

# ─── TIER 2: Grok (Validator + Analysis) ──────────────────────────
LLM_T2_BASE_URL=https://api.x.ai/v1
LLM_T2_API_KEY=
LLM_T2_MODEL=grok-4-0309
LLM_T2_CONFIDENCE_BUY=0.75

LLM_TIMEOUT_MS=60000
LLM_CANDIDATE_PICK_COUNT=10
LLM_CANDIDATE_MAX_AGE_MS=600000
MAX_OPEN_POSITIONS=3

MIN_FEE_CLAIM_SOL=2
GRADUATED_POLL_MS=30000
GRADUATED_LOOKBACK_MS=7200000
TRENDING_POLL_MS=60000
TRENDING_LOOKBACK_MS=600000
TRENDING_ENABLED=true
TRENDING_SOURCE=jupiter
TRENDING_ALLOW_DEGEN=false
TRENDING_INTERVAL=5m
TRENDING_LIMIT=100
TRENDING_ORDER_BY=volume
TRENDING_MIN_VOLUME_USD=0
TRENDING_MIN_SWAPS=0
TRENDING_MAX_RUG_RATIO=0.3
TRENDING_MAX_BUNDLER_RATE=0.5
GMGN_CACHE_TTL_MS=300000
POSITION_CHECK_MS=10000
MINT_COOLDOWN_MS=7200000

# Base chain config
BASE_ENABLED=false
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_PRIVATE_KEY=your_base_wallet_private_key
BASE_MCP_KEY=your_base_mcp_api_key
ALCHEMY_BASE_KEY=your_alchemy_base_key

# Position sizing
BASE_POSITION_SIZE_ETH=0.005
BASE_MAX_OPEN_POSITIONS=3
BASE_SAFETY_SL=-15

# Earning Agent / x402 Wallets
AGENT_WALLET_ADDRESS=your_solana_wallet_here
BASE_AGENT_WALLET=your_base_wallet_here

